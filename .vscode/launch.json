{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NestJS: start:dev (debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm.cmd",
      "runtimeArgs": ["run", "start:debug"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "restart": true,
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    }
  ]
}
